/* nav.css - styles for nav.html */
.top-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  background: #111E2D;
  color: #EEF5FF;
  padding: 0 24px;
  height: 60px;
  border-bottom: 1px solid #1A3048;
}
.nav-left, .nav-center, .nav-right {
  display: flex;
  align-items: center;
  gap: 16px;
}
.nav-title {
  font-size: 1.3rem;
  font-weight: 800;
  letter-spacing: -0.5px;
  cursor: pointer;
}
.theme-toggle {
  background: none;
  border: 1px solid #1A3048;
  border-radius: 8px;
  color: #EEF5FF;
  width: 36px;
  height: 36px;
  cursor: pointer;
  font-size: 1.1rem;
}
.theme-toggle:hover {
  background: #162539;
}
.nav-center button {
  background: none;
  border: none;
  color: #B3C7DD;
  font-size: 1rem;
  font-weight: 500;
  padding: 8px 14px;
  border-radius: 8px;
  cursor: pointer;
  transition: background 0.2s;
}
.nav-center button.active, .nav-center button:hover {
  background: #162539;
  color: #EEF5FF;
}
.user-avatar {
  width: 32px;
  height: 32px;
  border-radius: 50%;
  background: #2F80ED;
  color: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-weight: 700;
  font-size: 1rem;
}
.notify-btn {
  background: none;
  border: none;
  color: #EEF5FF;
  position: relative;
  font-size: 1.2rem;
  cursor: pointer;
}
.notify-badge {
  position: absolute;
  top: -6px;
  right: -8px;
  background: #F5A623;
  color: #111E2D;
  border-radius: 8px;
  font-size: 0.7rem;
  padding: 1px 6px;
  font-weight: 700;
}
.sign-in-btn {
  background: #06C0E0;
  color: #111E2D;
  border: none;
  border-radius: 8px;
  padding: 8px 18px;
  font-weight: 700;
  cursor: pointer;
}
.sign-in-btn:hover {
  background: #19d0f0;
}
