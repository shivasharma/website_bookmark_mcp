{
  "name": "bookmark-mcp-server",
  "version": "1.0.0",
  "description": "MCP Server for bookmarking websites",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "bookmark-mcp": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "start:api": "node dist/api.js",
    "dev:mcp": "tsx watch server/index.ts",
    "dev:api": "tsx watch server/api.ts"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "dotenv": "^16.6.1",
    "express-rate-limit": "^7.5.0",
    "express": "^4.18.2",
    "helmet": "^8.1.0",
    "cors": "^2.8.5",
    "express-session": "^1.18.2",
    "passport": "^0.7.0",
    "passport-github2": "^0.1.12",
    "passport-google-oauth20": "^2.0.0",
    "pg": "^8.16.3",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/cors": "^2.8.18",
    "@types/express": "^5.0.3",
    "@types/express-session": "^1.18.2",
    "@types/node": "^24.4.0",
    "@types/passport": "^1.0.17",
    "@types/passport-github2": "^1.2.9",
    "@types/passport-google-oauth20": "^2.0.16",
    "@types/pg": "^8.15.5",
    "tsx": "^4.20.5",
    "typescript": "^5.9.2"
  }
}
