# ── Server Configuration ──
PORT=3001
HOST=0.0.0.0
CERTBOT_EMAIL=you@example.com

# ── Database Configuration ──
DB_PASSWORD=your_secure_db_password_here
DATABASE_URL=postgresql://postgres:${DB_PASSWORD}@postgres:5432/bookmark_mcp

# ── Session & Security ──
SESSION_SECRET=your_very_complex_random_secret_change_in_production_min_32_chars
SESSION_COOKIE_SECURE=true
CORS_ORIGINS=https://ai.shivaprogramming.com,http://localhost:3001,http://127.0.0.1:3001

# ── Environment ──
NODE_ENV=production
ALLOW_LOCAL_FALLBACK=false

# ── OAuth - Google ──
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_CALLBACK_URL=https://ai.shivaprogramming.com/auth/google/callback

# ── OAuth - GitHub ──
CLIENT_ID_GITHUB=your_github_client_id
CLIENT_SECRET_GITHUB=your_github_client_secret
CALLBACK_URL_GITHUB=https://ai.shivaprogramming.com/auth/github/callback

